# If you are deploying via docker compose, you do not need to update these values:
# - POSTGRES_HOST
# - POSTGRES_PORT
# - REDIS_HOST
# - REDIS_PORT

# Should be "off" in prod.
DEBUG=on

# Options:
# - dev (for local development)
# - prod (for deployed versions)
ENVIRONMENT=dev

# Container role for the shared deployment image.
# Required in production containers. Docker Compose overrides this per service.
# Use "server" for the web app, "worker" for background workers, and "mcp"
# for the standalone FastMCP HTTP server.
APP_PROCESS_TYPE=

# Optional image override for docker-compose-prod.yml.
# Set to ghcr.io/<owner>/<repository>:latest when pulling the image built by GitHub Actions.
APP_IMAGE=

SECRET_KEY="super-secret-key"

ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

POSTGRES_HOST=db
POSTGRES_DB=osig
POSTGRES_USER=osig
POSTGRES_PORT=5432
POSTGRES_PASSWORD=osig

# Docker Compose uses Postgres. For native local development outside Docker,
# use DATABASE_URL=sqlite:///db.sqlite3 instead.
DATABASE_URL=postgres://osig:osig@db:5432/osig

REDIS_HOST=redis
REDIS_PASSWORD=osig
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://:osig@redis:6379/0

# Optional FastMCP HTTP sidecar settings.
MCP_HOST=127.0.0.1
MCP_PORT=8765
MCP_PATH=/mcp

# If you want to enable Social Auth via GitHub.
# Homepage URL: http://localhost:8000
# Authorization callback URL: http://localhost:8000/accounts/github/login/callback/
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

AWS_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

MAILGUN_API_KEY=

BUTTONDOWN_API_KEY=
POSTHOG_API_KEY=

SENTRY_DSN=
LOGFIRE_TOKEN=

# Stripe integration, not needed unless you want to sell access.
STRIPE_LIVE_SECRET_KEY=
STRIPE_TEST_SECRET_KEY=
DJSTRIPE_WEBHOOK_SECRET=
